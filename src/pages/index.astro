---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("dev")).filter(
  (p) => !p.data.draft && !p.data.hidden,
);

const FEATURED_IDS = ["theodosia", "riprap-nyc", "amanat"];
const featuredProjects = FEATURED_IDS.map((id) =>
  allProjects.find((p) => p.id === id),
).filter((p): p is NonNullable<typeof p> => p !== undefined);

const recentProjects = allProjects
  .filter((p) => !FEATURED_IDS.includes(p.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <!-- Hero -->
        <section>
          <h1 class="page-heading">
            Hi! I'm Adam.
            <iconify-icon
              icon="ph:hand-waving-light"
              class="wave-icon"
              aria-hidden="true"
              style="font-size: 1em; color: var(--accent-1);"></iconify-icon>
          </h1>
          <article class="prose hero-prose">
            <p>
              I'm a Software Engineer, Poet, and Designer. At
              <a
                href="https://www.ibm.com/z"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-link">IBM</a
              >, I build test automation and observability tooling for the Z
              mainframe. Outside of work, I build civic-AI systems like Riprap
              NYC, where every claim in a flood-exposure briefing cites a public
              record. I'm finishing an M.S. in Computer Engineering at
              <a
                href="https://engineering.nyu.edu/news/meet-adam-munawar-rahman-leveraging-ai-humanitarian-use"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-link">NYU Tandon</a
              >. I also write.
            </p>
          </article>
        </section>

        <!-- Credentials strip -->
        <section>
          <div class="cred-strip">
            <div class="cred-cell">
              <iconify-icon
                icon="ph:buildings-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Current role</span>
              <span class="cred-value">IBM</span>
              <span class="cred-sub">Test automation · Z</span>
            </div>
            <div class="cred-cell">
              <iconify-icon
                icon="ph:graduation-cap-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Education</span>
              <span class="cred-value">NYU Tandon</span>
              <span class="cred-sub">M.S. CE · 2027</span>
            </div>
            <div class="cred-cell">
              <iconify-icon
                icon="ph:trophy-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Hackathon wins</span>
              <span class="cred-value">Amanat</span>
              <span class="cred-sub">Auth0 2026</span>
            </div>
            <div class="cred-cell">
              <iconify-icon
                icon="ph:newspaper-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Profiled in</span>
              <span class="cred-value">NYU Tandon</span>
              <span class="cred-sub">Engineering · 2025</span>
            </div>
          </div>
        </section>

        <!-- Currently -->
        <section>
          <p class="currently-line">
            <span class="prompt">$</span>building Riprap NYC · reading <em
              >Seeing Like a State</em
            > · NYC
          </p>
        </section>

        <!-- Featured -->
        {
          featuredProjects.length > 0 && (
            <section class="space-y-2">
              <div class="section-header">
                <span class="section-label">Featured</span>
                <a href="/dev" class="meta-link">
                  See all
                </a>
              </div>
              <div class="home-feat-grid">
                {featuredProjects.map((p) => (
                  <a href={`/dev/${p.id}`} class="home-feat-card">
                    <div class="home-feat-title">{p.data.title}</div>
                    <p class="home-feat-desc">{p.data.description}</p>
                    <div class="home-feat-meta">
                      {p.data.role ?? (p.data.stack ? p.data.stack[0] : "")}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        <!-- Contact strip -->
        <section>
          <div class="contact-strip">
            <div class="contact-label">Get in touch</div>
            <p class="contact-body">
              If you're working on something in agentic AI infrastructure,
              observability, or developer platforms, or anything else on this
              site, write me.
            </p>
            <div class="contact-buttons">
              <a href="mailto:msrahmanadam@gmail.com" class="contact-btn">
                <iconify-icon icon="ph:envelope-simple-light" aria-hidden="true"
                ></iconify-icon>
                Email
              </a>
              <a
                href="https://linkedin.com/in/adamsrahman"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-btn"
              >
                <iconify-icon icon="ph:linkedin-logo-light" aria-hidden="true"
                ></iconify-icon>
                LinkedIn
              </a>
            </div>
          </div>
        </section>

        <!-- Recent projects -->
        <section class="space-y-2">
          <div class="section-header">
            <span class="section-label">Recent projects</span>
            <a href="/dev" class="meta-link">See all</a>
          </div>
          <ul class="ruled-list">
            {
              recentProjects.map((project) => (
                <li>
                  <a
                    href={`/dev/${project.id}`}
                    class="ruled-row no-number recent-row"
                  >
                    <span class="recent-main">
                      <span class="row-title">{project.data.title}</span>
                      <span class="recent-desc">
                        {project.data.description}
                      </span>
                    </span>
                    <span class="row-meta">
                      {project.data.date.getFullYear()}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Latest writings -->
        <section class="space-y-2">
          <div class="section-header">
            <span class="section-label">Latest writings</span>
            <a href="/blog" class="meta-link">See all</a>
          </div>
          <ul class="ruled-list">
            {
              blog.map((post, i) => (
                <li>
                  <ArrowCard entry={post} index={i} />
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Around the web -->
        <section class="space-y-2">
          <span class="section-label">Around the web</span>
          <div class="flex flex-wrap gap-3" style="padding-top: 0.25rem;">
            {
              SOCIALS.map((SOCIAL) => (
                <a
                  href={SOCIAL.HREF}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="meta-link"
                  aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                >
                  {SOCIAL.NAME}
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </aside>
  </Container>
</Layout>

<style>
  .recent-row {
    align-items: baseline;
  }

  .recent-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .recent-main :global(.row-title) {
    white-space: normal;
  }

  .recent-desc {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 0.778rem;
    line-height: 1.45;
    color: var(--text-muted);
  }

  .hero-link {
    color: var(--text-2);
    border-bottom: 1px solid var(--rule-strong);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .hero-link:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .home-feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--rule);
  }

  .home-feat-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem;
    text-decoration: none;
    border-right: 1px solid var(--rule);
    background: var(--bg-alt);
    transition: background 0.2s ease;
  }

  .home-feat-card:last-child {
    border-right: none;
  }

  .home-feat-card:hover {
    background: var(--hover);
  }

  .home-feat-title {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.722rem;
    font-weight: 600;
    color: var(--accent-1);
  }

  .home-feat-desc {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 0.778rem;
    line-height: 1.5;
    color: var(--text-2);
    flex: 1;
    margin: 0;
  }

  .home-feat-meta {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.556rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .home-feat-grid {
      grid-template-columns: 1fr;
    }
    .home-feat-card {
      border-right: none;
      border-bottom: 1px solid var(--rule);
    }
    .home-feat-card:last-child {
      border-bottom: none;
    }
  }
</style>

---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("dev")).filter(
  (p) => !p.data.draft && !p.data.hidden,
);

const HOME_FEATURED_COUNT = 3;
const featuredRank = (p: (typeof allProjects)[number]) =>
  p.data.featuredRank ?? Number.MAX_SAFE_INTEGER;
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => featuredRank(a) - featuredRank(b))
  .slice(0, HOME_FEATURED_COUNT);

const featuredIds = new Set(featuredProjects.map((p) => p.id));
const recentProjects = allProjects
  .filter((p) => !featuredIds.has(p.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <!-- Hero -->
        <section>
          <h1 class="page-heading">
            Hi! I'm Adam.
            <iconify-icon
              icon="ph:hand-waving-light"
              class="wave-icon"
              aria-hidden="true"
              style="font-size: 1em; color: var(--accent-1);"></iconify-icon>
          </h1>
          <article class="prose hero-prose">
            <p>
              I'm a software engineer, poet, and theatermaker. At
              <a
                href="https://www.ibm.com/z"
                target="_blank"
                rel="noopener noreferrer"
                class="hero-link">IBM</a
              > I lead test automation for the Z mainframe and ported Grafana k6 to
              z/OS upstream. The rest of my time goes to civic-AI tools, published
              poetry, and directing and designing for the stage.
            </p>
          </article>
        </section>

        <!-- Credentials strip -->
        <section>
          <div class="cred-strip">
            <div class="cred-cell">
              <iconify-icon
                icon="ph:buildings-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Current role</span>
              <span class="cred-value">IBM Z</span>
              <span class="cred-sub">Test automation lead</span>
            </div>
            <div class="cred-cell">
              <iconify-icon
                icon="ph:git-merge-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Open source</span>
              <span class="cred-value">k6 &rarr; z/OS</span>
              <span class="cred-sub">Merged upstream</span>
            </div>
            <div class="cred-cell">
              <iconify-icon
                icon="ph:trophy-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Recognition</span>
              <span class="cred-value">2nd of 1,600+</span>
              <span class="cred-sub">Arm AI Challenge 2025</span>
            </div>
            <div class="cred-cell">
              <iconify-icon
                icon="ph:graduation-cap-light"
                class="cred-icon"
                aria-hidden="true"></iconify-icon>
              <span class="cred-label">Education</span>
              <span class="cred-value">NYU Tandon</span>
              <span class="cred-sub">M.S. CE 2027</span>
            </div>
          </div>
        </section>

        <!-- Stack -->
        <section>
          <div class="skills-strip">
            <span class="skills-label">Stack</span>
            <ul class="skills-chips">
              <li class="skill-chip">Go</li>
              <li class="skill-chip">Python</li>
              <li class="skill-chip">Rust/WASM</li>
              <li class="skill-chip">TypeScript</li>
              <li class="skill-chip">z/OS</li>
              <li class="skill-chip">Grafana k6</li>
              <li class="skill-chip">MCP</li>
              <li class="skill-chip">Ansible</li>
              <li class="skill-chip">Jenkins</li>
              <li class="skill-chip">load testing</li>
              <li class="skill-chip">observability</li>
              <li class="skill-chip">agentic AI</li>
              <li class="skill-chip">geospatial</li>
            </ul>
          </div>
        </section>

        <!-- Currently -->
        <section>
          <p class="currently-line">
            <span class="prompt">$</span>building Riprap NYC · reading <em
              >Seeing Like a State</em
            > · NYC
          </p>
        </section>

        <!-- Disciplines -->
        <section class="space-y-2">
          <div class="section-header">
            <span class="section-label">What I do</span>
          </div>
          <ul class="ruled-list">
            <li>
              <a href="/dev" class="ruled-row no-number disc-row">
                <span class="disc-main">
                  <span class="row-title">Engineering &amp; open source</span>
                  <span class="disc-desc">
                    Test automation for IBM Z, Grafana k6 on z/OS, and open
                    source tools.
                  </span>
                </span>
                <span class="row-meta">/dev</span>
              </a>
            </li>
            <li>
              <a href="/dev" class="ruled-row no-number disc-row">
                <span class="disc-main">
                  <span class="row-title">Civic-AI &amp; geospatial</span>
                  <span class="disc-desc">
                    DreamMeridian, Riprap, and amanat.
                  </span>
                </span>
                <span class="row-meta">/dev</span>
              </a>
            </li>
            <li>
              <a href="/theater" class="ruled-row no-number disc-row">
                <span class="disc-main">
                  <span class="row-title">Theater</span>
                  <span class="disc-desc">
                    Directing, sound, and set design. Directed Disgraced.
                  </span>
                </span>
                <span class="row-meta">/theater</span>
              </a>
            </li>
            <li>
              <a href="/poetry" class="ruled-row no-number disc-row">
                <span class="disc-main">
                  <span class="row-title">Poetry</span>
                  <span class="disc-desc">
                    Published in Barzakh, Collide-oscope, and Four Tulips.
                  </span>
                </span>
                <span class="row-meta">/poetry</span>
              </a>
            </li>
            <li>
              <a href="/design" class="ruled-row no-number disc-row">
                <span class="disc-main">
                  <span class="row-title">Design</span>
                  <span class="disc-desc">
                    Theater posters, programs, and interfaces.
                  </span>
                </span>
                <span class="row-meta">/design</span>
              </a>
            </li>
          </ul>
        </section>

        <!-- Featured -->
        {
          featuredProjects.length > 0 && (
            <section class="space-y-2">
              <div class="section-header">
                <span class="section-label">Featured</span>
                <a href="/dev" class="meta-link">
                  See all
                </a>
              </div>
              <div class="home-feat-grid">
                {featuredProjects.map((p) => (
                  <a href={`/dev/${p.id}`} class="home-feat-card">
                    <div class="home-feat-title">{p.data.title}</div>
                    <p class="home-feat-desc">{p.data.description}</p>
                    <div class="home-feat-meta">
                      {p.data.role ?? (p.data.stack ? p.data.stack[0] : "")}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        <!-- Contact strip -->
        <section>
          <div class="contact-strip">
            <div class="contact-label">Get in touch</div>
            <p class="contact-body">
              If you're building something where it matters who gets seen and
              counted, in engineering, civic tech, theater, poetry, or design,
              write me.
            </p>
            <div class="contact-buttons">
              <a
                href="https://linkedin.com/in/adamsrahman"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-btn"
              >
                <iconify-icon icon="ph:linkedin-logo-light" aria-hidden="true"
                ></iconify-icon>
                LinkedIn
              </a>
            </div>
          </div>
        </section>

        <!-- Recent projects -->
        <section class="space-y-2">
          <div class="section-header">
            <span class="section-label">Recent projects</span>
            <a href="/dev" class="meta-link">See all</a>
          </div>
          <ul class="ruled-list">
            {
              recentProjects.map((project) => (
                <li>
                  <a
                    href={`/dev/${project.id}`}
                    class="ruled-row no-number recent-row"
                  >
                    <span class="recent-main">
                      <span class="row-title">{project.data.title}</span>
                      <span class="recent-desc">
                        {project.data.description}
                      </span>
                    </span>
                    <span class="row-meta">
                      {project.data.date.getFullYear()}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Latest writings -->
        <section class="space-y-2">
          <div class="section-header">
            <span class="section-label">Latest writings</span>
            <a href="/blog" class="meta-link">See all</a>
          </div>
          <ul class="ruled-list">
            {
              blog.map((post, i) => (
                <li>
                  <ArrowCard entry={post} index={i} />
                </li>
              ))
            }
          </ul>
        </section>

        <!-- Around the web -->
        <section>
          <ul class="social-row" aria-label="Social links">
            <li>
              <a
                href="https://github.com/msradam"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
              >
                <iconify-icon icon="ph:github-logo" aria-hidden="true"
                ></iconify-icon>
              </a>
            </li>
            <li>
              <a
                href="https://linkedin.com/in/adamsrahman"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
              >
                <iconify-icon icon="ph:linkedin-logo" aria-hidden="true"
                ></iconify-icon>
              </a>
            </li>
            <li>
              <a
                href="https://medium.com/@msradam"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Medium"
              >
                <iconify-icon icon="ph:medium-logo" aria-hidden="true"
                ></iconify-icon>
              </a>
            </li>
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>

<style>
  .recent-row,
  .disc-row {
    align-items: baseline;
  }

  .recent-main,
  .disc-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .recent-main :global(.row-title),
  .disc-main :global(.row-title) {
    white-space: normal;
  }

  .recent-desc,
  .disc-desc {
    font-family: var(--sans);
    font-size: 0.778rem;
    line-height: 1.45;
    color: var(--text-muted);
  }

  .hero-link {
    color: var(--text-2);
    border-bottom: 1px solid var(--rule-strong);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .hero-link:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .skills-strip {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .skills-label {
    font-family: var(--mono);
    font-size: 0.611rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .skills-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .skill-chip {
    font-family: var(--mono);
    font-size: 0.611rem;
    letter-spacing: 0.04em;
    color: var(--text-2);
    border: 1px solid var(--rule);
    padding: 0.1rem 0.45rem;
    background: var(--bg-alt);
  }

  .home-feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--rule);
  }

  .home-feat-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem;
    text-decoration: none;
    border-right: 1px solid var(--rule);
    background: var(--bg-alt);
    transition: background 0.2s ease;
  }

  .home-feat-card:last-child {
    border-right: none;
  }

  .home-feat-card:hover {
    background: var(--hover);
  }

  .home-feat-title {
    font-family: var(--mono);
    font-size: 0.722rem;
    font-weight: 600;
    color: var(--accent-1);
  }

  .home-feat-desc {
    font-family: var(--sans);
    font-size: 0.778rem;
    line-height: 1.5;
    color: var(--text-2);
    flex: 1;
    margin: 0;
  }

  .home-feat-meta {
    font-family: var(--mono);
    font-size: 0.556rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .home-feat-grid {
      grid-template-columns: 1fr;
    }
    .home-feat-card {
      border-right: none;
      border-bottom: 1px solid var(--rule);
    }
    .home-feat-card:last-child {
      border-bottom: none;
    }
  }
</style>

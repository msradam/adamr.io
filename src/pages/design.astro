---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { DESIGN } from "@consts";

const theaterWork = [
  {
    src: "/images/design/anandi.jpg",
    alt: "Anandi production poster",
    title: "Anandi",
    meta1: "Thesis film · Designer",
    meta2: "Dir. Thanmye Lagudu · 2019",
  },
  {
    src: "/images/design/disgraced.png",
    alt: "Disgraced production poster",
    title: "Disgraced",
    meta1: "Second Stage · Director & designer",
    meta2: "Malcolm X House · 2018",
  },
  {
    src: "/images/design/esque.jpg",
    alt: "What the Esque production poster",
    title: "What the Esque",
    meta1: "Queer film + arts show · Designer",
    meta2: "Westco Café · 2018",
  },
  {
    src: "/images/design/papiyon.png",
    alt: "La Violecion of My Papiton production poster",
    title: "La Violecion of My Papiton",
    meta1: "By Arline Pierre-Louis · Designer",
    meta2: "Patricelli '92 Theater · 2017",
  },
  {
    src: "/images/design/rhino.png",
    alt: "Rhinoceros production poster",
    title: "Rhinoceros",
    meta1: "Ionesco · Asst. director & designer",
    meta2: "Second Stage · 2018",
  },
];

const productWork = [
  {
    src: "/images/riprap-nyc.png",
    alt: "Riprap NYC flood-exposure briefing interface",
    title: "Riprap NYC",
    meta1: "Briefing UI · Solo",
    meta2: "Civic AI · 2026",
  },
  {
    src: "/images/ariadne-nyc.png",
    alt: "Ariadne NYC accessible routing interface",
    title: "Ariadne NYC",
    meta1: "Route planner interface · Hackathon",
    meta2: "Geospatial AI · 2026",
  },
];

const marpThemes = [
  {
    src: "/images/marp-carbon.png",
    alt: "Carbon Marp theme title slide",
    title: "Carbon",
    meta1: "IBM Carbon Design System",
    meta2: "Marp theme · 2026",
  },
  {
    src: "/images/marp-neobrutalism.png",
    alt: "Neobrutalism Marp theme title slide",
    title: "Neobrutalism",
    meta1: "Thick borders · Space Grotesk",
    meta2: "Marp theme · 2026",
  },
  {
    src: "/images/marp-tufte.png",
    alt: "Tufte Marp theme title slide",
    title: "Tufte",
    meta1: "Edward Tufte · ET Book",
    meta2: "Marp theme · 2026",
  },
  {
    src: "/images/marp-bold.png",
    alt: "Bold Marp theme title slide",
    title: "Bold",
    meta1: "Bold Design System · UFSC",
    meta2: "Marp theme · 2026",
  },
];

const papiyonPhotos = [
  {
    src: "/images/theater/papiyon-1.jpg",
    alt: "La Violecion of My Papiyon production photo",
  },
  {
    src: "/images/theater/papiyon-2.jpg",
    alt: "La Violecion of My Papiyon production photo",
  },
  {
    src: "/images/theater/papiyon-3.jpg",
    alt: "La Violecion of My Papiyon production photo",
  },
  {
    src: "/images/theater/papiyon-4.jpg",
    alt: "La Violecion of My Papiyon production photo",
  },
];
---

<Layout title={DESIGN.TITLE} description={DESIGN.DESCRIPTION}>
  <Container>
    <div class="space-y-8">
      <div>
        <span class="section-label">Design</span>
        <h1
          class="page-heading"
          style="margin-top: 0.5rem; margin-bottom: 0.5rem;"
        >
          Posters, programs, and interface work.
        </h1>
        <p class="body-text-sm">
          Graphic design for theater and film produced at Wesleyan between 2017
          and 2019, plus interface work from current projects. Everything here
          is shipped; the posters were printed and the products are running.
        </p>
      </div>

      <section class="space-y-4">
        <div
          class="section-header"
          style="padding-bottom: 0.5rem; border-bottom: 1px solid var(--rule);"
        >
          <span class="section-label"
            >Theater &amp; film posters · Wesleyan 2017–2019</span
          >
          <span class="row-meta"
            >{theaterWork.length.toString().padStart(2, "0")}</span
          >
        </div>
        <div class="poster-grid">
          {
            theaterWork.map((item) => (
              <div class="poster-item">
                <button
                  class="lightbox-trigger poster-frame"
                  data-src={item.src}
                  data-alt={item.alt}
                  aria-label={`View ${item.title} poster`}
                >
                  <img
                    src={item.src}
                    alt={item.alt}
                    class="poster-img"
                    loading="lazy"
                  />
                </button>
                <div class="poster-meta">
                  <div class="poster-name">{item.title}</div>
                  <div class="poster-detail">{item.meta1}</div>
                  <div class="poster-detail">{item.meta2}</div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="space-y-4" style="margin-top: 2rem;">
        <div
          class="section-header"
          style="padding-bottom: 0.5rem; border-bottom: 1px solid var(--rule);"
        >
          <span class="section-label">Product &amp; interface · 2025–</span>
          <span class="row-meta"
            >{String(productWork.length).padStart(2, "0")}</span
          >
        </div>
        <div class="poster-grid">
          {
            productWork.map((item) => (
              <div class="poster-item">
                <button
                  class="lightbox-trigger poster-frame interface-frame"
                  data-src={item.src}
                  data-alt={item.alt}
                  aria-label={`View ${item.title} screenshot`}
                >
                  <img
                    src={item.src}
                    alt={item.alt}
                    class="poster-img"
                    loading="lazy"
                  />
                </button>
                <div class="poster-meta">
                  <div class="poster-name">{item.title}</div>
                  <div class="poster-detail">{item.meta1}</div>
                  <div class="poster-detail">{item.meta2}</div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="space-y-4" style="margin-top: 2rem;">
        <div
          class="section-header"
          style="padding-bottom: 0.5rem; border-bottom: 1px solid var(--rule);"
        >
          <span class="section-label">Presentation themes · Marp</span>
          <span class="row-meta"
            >{String(marpThemes.length).padStart(2, "0")}</span
          >
        </div>
        <p class="body-text-xs" style="color: var(--text-muted);">
          Open-source <a
            href="https://marp.app"
            target="_blank"
            rel="noopener noreferrer"
            class="content-link">Marp</a
          >
          themes, each with light and dark variants and Mermaid diagram theming. Built
          on established design systems and typographic traditions.
        </p>
        <div class="theme-grid">
          {
            marpThemes.map((item) => (
              <div class="poster-item">
                <button
                  class="lightbox-trigger poster-frame theme-frame"
                  data-src={item.src}
                  data-alt={item.alt}
                  aria-label={`View ${item.title} theme slide`}
                >
                  <img
                    src={item.src}
                    alt={item.alt}
                    class="poster-img"
                    loading="lazy"
                  />
                </button>
                <div class="poster-meta">
                  <div class="poster-name">{item.title}</div>
                  <div class="poster-detail">{item.meta1}</div>
                  <div class="poster-detail">{item.meta2}</div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="space-y-4" style="margin-top: 2rem;">
        <div
          class="section-header"
          style="padding-bottom: 0.5rem; border-bottom: 1px solid var(--rule);"
        >
          <span class="section-label">Production photos</span>
          <span class="row-meta"
            >{String(papiyonPhotos.length).padStart(2, "0")}</span
          >
        </div>
        <p class="body-text-xs" style="color: var(--text-muted);">
          Set design for <em>La Violecion of My Papiyon</em> by Arline Pierre-Louis.
          SHADES, Patricelli '92 Theater, Wesleyan University, April 2018. Photos
          by Dani Smotrich-Barr.
        </p>
        <div class="photo-grid">
          {
            papiyonPhotos.map((item) => (
              <button
                class="lightbox-trigger photo-frame"
                data-src={item.src}
                data-alt={item.alt}
                aria-label="View production photo"
              >
                <img
                  src={item.src}
                  alt={item.alt}
                  class="photo-img"
                  loading="lazy"
                />
              </button>
            ))
          }
        </div>
      </section>
    </div>

    <dialog
      id="lightbox"
      class="lightbox-dialog m-0 bg-transparent p-4 backdrop:bg-black/80 backdrop:backdrop-blur-sm"
    >
      <button
        id="lightbox-close"
        class="absolute top-4 right-4 z-10 flex size-10 items-center justify-center rounded-full bg-black/50 text-white transition-colors hover:bg-black/70"
        aria-label="Close"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="size-5"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-h-[90dvh] max-w-full object-contain"
        style="border-radius: 3px;"
      />
    </dialog>
  </Container>
</Layout>

<style>
  .poster-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 1.25rem;
  }

  .poster-frame {
    display: block;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: 2px;
    cursor: zoom-in;
    background: var(--bg-alt);
    padding: 0;
  }

  .poster-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
    display: block;
  }

  .poster-frame:hover .poster-img {
    opacity: 0.88;
  }

  .poster-meta {
    margin-top: 0.6rem;
  }

  .poster-name {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .poster-detail {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.556rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 0.2rem;
    line-height: 1.5;
  }

  dialog[open] {
    display: flex;
    position: fixed;
    inset: 0;
    z-index: 50;
    width: 100dvw;
    max-width: 100dvw;
    height: 100dvh;
    max-height: 100dvh;
    align-items: center;
    justify-content: center;
    animation: fade-in 0.2s ease-out;
  }
  dialog[open]::backdrop {
    animation: fade-in 0.2s ease-out;
  }
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  dialog[open] img {
    animation: scale-in 0.25s ease-out;
  }
  @keyframes scale-in {
    from {
      opacity: 0;
      transform: scale(0.92);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .interface-frame {
    aspect-ratio: 16/10;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1.25rem;
  }

  .theme-frame {
    aspect-ratio: 16/9;
    background: #ffffff;
  }

  .theme-frame .poster-img {
    object-fit: cover;
    object-position: top left;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .photo-frame {
    display: block;
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    border: 1px solid var(--rule);
    border-radius: 2px;
    cursor: zoom-in;
    background: #0c0c0c;
    padding: 0;
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
    display: block;
  }

  .photo-frame:hover .photo-img {
    opacity: 0.88;
  }

  @media (max-width: 640px) {
    .poster-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .photo-grid {
      grid-template-columns: 1fr;
    }

    .theme-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initLightbox() {
    const dialog = document.getElementById("lightbox") as HTMLDialogElement;
    const img = document.getElementById("lightbox-img") as HTMLImageElement;
    const closeBtn = document.getElementById("lightbox-close");

    document.querySelectorAll(".lightbox-trigger").forEach((btn) => {
      btn.addEventListener("click", () => {
        const src = (btn as HTMLElement).dataset.src || "";
        const alt = (btn as HTMLElement).dataset.alt || "";
        img.src = src;
        img.alt = alt;
        dialog.showModal();
      });
    });

    closeBtn?.addEventListener("click", () => dialog.close());
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  document.addEventListener("DOMContentLoaded", initLightbox);
  document.addEventListener("astro:after-swap", initLightbox);
</script>

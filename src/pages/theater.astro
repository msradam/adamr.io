---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";

const productions = [
  {
    img: "/images/design/disgraced.png",
    alt: "Disgraced poster, designed by Adam Rahman",
    role: "Director · Poster designer",
    title: "Disgraced",
    by: "by Ayad Akhtar",
    meta: "Wesleyan Second Stage · Malcolm X House · Dec 2018",
    notes: [
      "Ayad Akhtar's Pulitzer-winning one-act. A Pakistani-American corporate lawyer's hidden Muslim identity surfaces over a dinner party and blows everything apart. Two years earlier I'd acted in a Readers Theater reading of the same play as Hussein Malik/Abe Jensen, so I came to the script knowing it from the inside out.",
      '<span class="didwhat">What I did:</span> directed, and designed the poster. We set up in the basement of Malcolm X House, an improvised black box with borrowed furniture and Ikea dimmers where a lighting rig should have been. Stage manager: Thanmye Lagudu. Set designer: Angelica. I wrote about the directing in <a href="/blog/sacred-geometry" class="content-link">Sacred Geometry: On Directing <em>Disgraced</em></a>.',
    ],
  },
  {
    img: "/images/theater/rrg-poster.jpg",
    alt: "Really Really Gorgeous poster, The Tank NYC",
    role: "Stage Manager",
    title: "Really Really Gorgeous",
    by: "by Nick Mecikalski, directed by Miranda Haymon",
    meta: "The Tank, NYC · Jan 23 – Feb 9, 2020 · World premiere",
    notes: [
      'Nick Mecikalski\'s world premiere, directed by Miranda Haymon. Two women in a moldy shack at the end of a flooded America; the play is a two-hander and it\'s relentless. Produced by The Tank with Lucy Powis and The Hodgepodge Group. Got a <a href="https://www.nytimes.com/2020/02/03/theater/really-really-gorgeous-review.html" target="_blank" rel="noopener noreferrer" class="content-link">New York Times review</a>.',
      '<span class="didwhat">What I did:</span> stage managed. Kept the prompt book, ran rehearsals, called the show in performance, held the production schedule together through a packed run.',
    ],
  },
  {
    img: "/images/theater/action.jpg",
    alt: "Action by Sam Shepard, Wesleyan CFA dress rehearsal. Photo by Sandy Aldieri.",
    role: "Stage Manager",
    title: "Action",
    by: "by Sam Shepard, directed by Ray Achan",
    meta: "Wesleyan senior thesis · 2019",
    notes: [
      "Sam Shepard's 1974 one-act. Four characters in an isolated cabin on Christmas, after some unspecified collapse outside; the play is very still and very tense. Ray Achan's directing thesis.",
      '<span class="didwhat">What I did:</span> stage managed. Kept the prompt book, ran rehearsals, called the show. Held the line between director and production so Ray could focus on the work.',
    ],
  },
  {
    img: "/images/theater/edith.jpg",
    alt: "Edith Can Shoot Things and Hit Them, Wesleyan Second Stage production photo",
    role: "Sound Designer",
    title: "Edith Can Shoot Things and Hit Them",
    by: "by A. Rey Pamatmat",
    meta: "Second Stage, Wesleyan · 2018",
    notes: [
      "A. Rey Pamatmat's play about two Filipino American siblings living alone on a farm in Middle America; their parents left and didn't come back. A third character shows up and upsets the fragile equilibrium they've built. Originally produced at the 2011 Humana Festival of New American Plays.",
      '<span class="didwhat">What I did:</span> designed sound. Built day-scene ambience and night-scene cue stacks, sourced and cut every cue, specced and patched the rig, ran sound through tech and performance.',
    ],
  },
  {
    img: "/images/design/papiyon.png",
    alt: "La Violecion of My Papiyon poster",
    role: "Set Designer",
    title: "La Violecion of My Papiyon",
    by: "by Arline Pierre-Louis, directed by Ray Achan & Ruby Fludzinski",
    meta: "SHADES · Patricelli '92 Theater, Wesleyan · Apr 2018",
    notes: [
      "New work by Arline Pierre-Louis, produced by SHADES, Wesleyan's student collective for theater by and about people of color. Directed by Ray Achan and Ruby Fludzinski. Ray also directed <em>Action</em>, which I stage managed the following year.",
      '<span class="didwhat">What I did:</span> designed the set. Ground plan and elevations, build costing, supervised the build with the tech crew, paint and dressing.',
    ],
  },
  {
    img: "/images/theater/life-is-a-dream.jpg",
    alt: "Life is a Dream, Wesleyan CFA production photo",
    role: "Actor · Clotaldo",
    title: "Life is a Dream",
    by: "by Pedro Calderón de la Barca, directed by Shira Milikowsky",
    meta: "Wesleyan Center for the Arts · 2017",
    notes: [
      "Calderón de la Barca's verse drama, one of the great works of the Spanish Golden Age. Prince Segismundo has been imprisoned since birth by a prophecy; the play turns on whether fate can be escaped. CFA main-stage production, one of my first at Wesleyan.",
      '<span class="didwhat">What I did:</span> played Clotaldo, Segismundo\'s tutor and the keeper of the secret.',
    ],
  },
  {
    img: "/images/theater/islands-poster.jpg",
    alt: "Islands, Wesleyan CFA poster",
    role: "Actor · Harjito / Sukarno",
    title: "Islands",
    by: "directed by Ronald Jenkins",
    meta: "Wesleyan Center for the Arts · 2017",
    notes: [
      "Ensemble-devised production on the CFA main stage, directed by Professor Ronald Jenkins. The work drew on island histories and collective memory; the form matched the content, built in the room by the room.",
      '<span class="didwhat">What I did:</span> played Harjito and Sukarno.',
    ],
  },
  {
    img: "/images/design/rhino.png",
    alt: "Rhinoceros poster",
    role: "Social Media Manager",
    title: "Rhinoceros",
    by: "by Eugene Ionesco, translated by Derek Prouse, directed by Jordan Tragash",
    meta: "Wesleyan Second Stage · Patricelli '92 Theater · May 2018",
    notes: [
      "Ionesco's 1959 absurdist classic, in Derek Prouse's translation. A small French town's inhabitants begin turning into rhinoceroses one by one; the holdouts dwindle, resistance becomes its own kind of loneliness. One of the great plays about conformity and what it costs to refuse it.",
      '<span class="didwhat">What I did:</span> ran social media for the production. Wrote and scheduled posts, coordinated promotional assets with Jordan, pushed ticket sales through the three-night run.',
    ],
  },
];
---

<Layout
  title="Theater"
  description="Theater credits from Wesleyan University and New York, 2017–2020. Eight productions across four years: director, stage manager, sound designer, set designer, actor, social media."
>
  <Container>
    <div class="theater-doc">
      <!-- Title block -->
      <div class="theater-title">
        <span class="section-label">Theater</span>
        <h1 class="page-heading" style="margin-top: 0.5rem; margin-bottom: 0;">
          Theater work.
        </h1>
        <p class="t-lede">
          Eight productions across four years, mostly at Wesleyan Second Stage,
          one professional gig in New York. I did a bit of everything: directed,
          stage managed, designed sound and sets, acted, ran social. Listed here
          by role rather than chronology.
        </p>
      </div>

      <!-- Productions -->
      <section class="t-section">
        <div class="section-header">
          <span class="section-label">Productions</span>
          <span class="row-meta">{productions.length} productions</span>
        </div>

        <div class="prod-list">
          {
            productions.map((p) => (
              <article class="prod">
                <div class="prod-poster">
                  <img src={p.img} alt={p.alt} loading="lazy" />
                </div>
                <div class="prod-body">
                  <span class="prod-role">{p.role}</span>
                  <h2 class="prod-title">{p.title}</h2>
                  <p class="prod-by">{p.by}</p>
                  <div class="prod-meta">{p.meta}</div>
                  {p.notes.map((note) => (
                    <p class="prod-note" set:html={note} />
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Production photos -->
      <section class="t-section">
        <div class="section-header">
          <span class="section-label">Photos · Disgraced, Dec 2018</span>
        </div>

        <div class="photos-grid">
          <figure class="photo-item photo-item--wide">
            <img
              src="/images/sacred-geometry/haha_isaac.jpg"
              alt="The dinner party scene: Arnaav Bhavanani, Abhishek Fakiraswaminath, Dache Rogers, Ava Biery"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/d5.JPG"
              alt="Arnaav Bhavanani as Amir"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/d1.JPG"
              alt="Dache Rogers, Arnaav Bhavanani, Abhishek Fakiraswaminath"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/d4.JPG"
              alt="Abhishek Fakiraswaminath and Ava Biery"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/directing.png"
              alt="Rehearsal, Adam directing the cast"
              loading="lazy"
            />
          </figure>
        </div>
        <p class="photo-credit">
          Photography by Elijah Comas '22. Rehearsal photo by Thanmye Lagudu
          '20.
        </p>
      </section>

      <!-- Company -->
      <section class="t-section">
        <div class="section-header">
          <span class="section-label">Company · Wesleyan Second Stage</span>
        </div>

        <div class="company-block">
          <h2 class="company-name">Second Stage</h2>
          <div class="company-where">
            Student-run theater company · Wesleyan University
          </div>
          <div class="company-rows">
            <div class="company-row">
              <div class="company-role">
                Staff
                <em
                  >Two academic years on the company. Helped support productions
                  across the season: everything from load-ins to strike.</em
                >
              </div>
              <div class="company-year">2017 – 2019</div>
            </div>
            <div class="company-row">
              <div class="company-role">
                Lights &amp; Rigging Liaison
                <em
                  >Point person for the lighting rig and rigging hardware.
                  Coordinated with CFA technical staff on hangs and refocuses.</em
                >
              </div>
              <div class="company-year">2017 – 2018</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </Container>
</Layout>

<style>
  .theater-doc {
    padding: 0 0 5rem;
  }

  .theater-title {
    margin-bottom: 3.5rem;
  }

  .t-lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--text-2);
    max-width: 620px;
    margin: 1rem 0 0;
  }

  .t-section {
    margin-bottom: 4rem;
    scroll-margin-top: 2.5rem;
  }

  .t-section .section-header {
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1.5rem;
  }

  /* Unified production list — poster beside each production */
  .prod-list {
    display: grid;
  }

  .prod {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1.75rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }

  .prod:last-child {
    border-bottom: none;
  }

  .prod-poster {
    aspect-ratio: 3/4;
    border: 1px solid var(--rule);
    overflow: hidden;
    background: var(--doc-bg);
  }

  .prod-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .prod-role {
    display: inline-block;
    font-family: var(--mono);
    font-size: var(--label); /* VT323 optical bump from 0.556 */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-2);
    margin-bottom: 0.45rem;
  }

  .prod-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.4rem;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 0.3rem;
    color: var(--text);
  }

  .prod-by {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--text-2);
    margin: 0 0 0.5rem;
  }

  .prod-meta {
    font-family: var(--mono);
    font-size: var(--meta); /* VT323 optical bump from 0.556 */
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.9rem;
    padding: 0.5rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .prod-note {
    font-family: var(--sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text);
    margin: 0;
    max-width: 60ch;
    text-wrap: pretty;
  }

  .prod-note + .prod-note {
    margin-top: 0.75rem;
  }

  .didwhat {
    color: var(--text-2);
    font-style: italic;
  }

  /* Production photo grid */
  .photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 0.5rem;
  }

  .photo-item {
    margin: 0;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .photo-item--wide {
    grid-column: span 2;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: unset;
  }

  .photo-item--wide img {
    aspect-ratio: 16 / 9;
  }

  .photo-item:not(.photo-item--wide) img {
    aspect-ratio: 4 / 3;
  }

  .photo-credit {
    font-family: var(--mono);
    font-size: var(--meta); /* VT323 optical bump from 0.5 */
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-top: 0.6rem;
    text-transform: uppercase;
  }

  /* Company block */
  .company-block {
    background: var(--bg-alt);
    border: 1px solid var(--rule);
    padding: 1.65rem 1.75rem 1.5rem;
  }

  .company-name {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.2rem;
    margin: 0 0 0.3rem;
    letter-spacing: -0.005em;
    color: var(--text);
  }

  .company-where {
    font-family: var(--mono);
    font-size: var(--meta); /* VT323 optical bump from 0.556 */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .company-rows {
    display: grid;
    gap: 0.75rem;
  }

  .company-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--rule);
    align-items: baseline;
  }

  .company-row:first-child {
    border-top: none;
    padding-top: 0;
  }

  .company-role {
    font-family: var(--sans);
    font-size: 0.95rem;
    color: var(--text);
  }

  .company-role em {
    color: var(--text-2);
    font-style: italic;
    font-size: 0.83rem;
    display: block;
    margin-top: 0.2rem;
    line-height: 1.5;
  }

  .company-year {
    font-family: var(--mono);
    font-size: var(--meta); /* VT323 optical bump from 0.611 */
    letter-spacing: 0.06em;
    color: var(--text-muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (max-width: 880px) {
    .photos-grid {
      grid-template-columns: 1fr 1fr;
    }
    .photo-item--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .theater-doc {
      padding: 0 0 3.5rem;
    }
    .t-lede {
      font-size: 1rem;
    }
    .theater-title {
      margin-bottom: 2.5rem;
    }
    .prod {
      grid-template-columns: 84px 1fr;
      gap: 1rem;
      padding: 1.25rem 0;
    }
    .prod-title {
      font-size: 1.15rem;
    }
    .prod-meta {
      font-size: var(--meta);
    }
    .prod-note {
      font-size: 0.875rem;
    }
    .photos-grid {
      grid-template-columns: 1fr;
    }
    .photo-item--wide {
      grid-column: span 1;
    }
    .photo-item--wide img {
      aspect-ratio: 4 / 3;
    }
    .company-block {
      padding: 1.25rem 1.1rem;
    }
    .company-row {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>

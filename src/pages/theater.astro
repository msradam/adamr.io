---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
---

<Layout
  title="Theater"
  description="Theater credits from Wesleyan University and New York, 2017–2020. Eight productions across four years: director, stage manager, sound designer, set designer, actor, social media."
>
  <Container>
    <div class="theater-doc">
      <!-- Title block -->
      <div class="theater-title">
        <div class="t-kicker">Productions · 2017 – 2020</div>
        <h1 class="t-h1">Theater work.</h1>
        <p class="t-lede">
          Eight productions across four years, mostly at Wesleyan Second Stage,
          one professional gig in New York. I did a bit of everything: directed,
          stage managed, designed sound and sets, acted, ran social. Listed here
          by role rather than chronology.
        </p>

        <div class="roles-strip" aria-label="Roles held">
          <div class="role-cell">
            <span class="role-count">01</span>
            <span class="role-name">Director</span>
            <span class="role-note">one production</span>
          </div>
          <div class="role-cell">
            <span class="role-count">02</span>
            <span class="role-name">Stage Manager</span>
            <span class="role-note">two productions</span>
          </div>
          <div class="role-cell">
            <span class="role-count">03</span>
            <span class="role-name">Sound Designer</span>
            <span class="role-note">one production</span>
          </div>
          <div class="role-cell">
            <span class="role-count">04</span>
            <span class="role-name">Set Designer</span>
            <span class="role-note">one production</span>
          </div>
          <div class="role-cell">
            <span class="role-count">05</span>
            <span class="role-name">Actor</span>
            <span class="role-note">two productions</span>
          </div>
          <div class="role-cell">
            <span class="role-count">06</span>
            <span class="role-name">Social Media</span>
            <span class="role-note">one production</span>
          </div>
        </div>
      </div>

      <!-- Posters -->
      <section class="t-section">
        <div class="t-sec-head">
          <div class="t-sec-num">a.</div>
          <div>
            <h2 class="t-h2">Posters.</h2>
            <div class="t-sec-sub">Eight productions</div>
          </div>
        </div>

        <div class="posters-grid">
          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/design/disgraced.png"
                alt="Disgraced poster, designed by Adam Rahman"
                loading="lazy"
              />
            </div>
            <div class="pname">Disgraced</div>
            <div class="pmeta">
              <span class="prole">Director · Poster designer</span>Second Stage,
              Wesleyan · '18
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/theater/rrg-poster.jpg"
                alt="Really Really Gorgeous poster, The Tank NYC"
                loading="lazy"
              />
            </div>
            <div class="pname">Really Really Gorgeous</div>
            <div class="pmeta">
              <span class="prole">Stage Mgr</span>The Tank, NYC
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/theater/action.jpg"
                alt="Action by Sam Shepard, Wesleyan CFA dress rehearsal. Photo by Sandy Aldieri."
                loading="lazy"
              />
            </div>
            <div class="pname">Action</div>
            <div class="pmeta">
              <span class="prole">Stage Mgr</span>Wesleyan senior thesis
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/theater/edith.jpg"
                alt="Edith Can Shoot Things and Hit Them, Wesleyan Second Stage production photo"
                loading="lazy"
              />
            </div>
            <div class="pname">Edith Can Shoot Things and Hit Them</div>
            <div class="pmeta">
              <span class="prole">Sound Designer</span>Second Stage, Wesleyan
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/design/papiyon.png"
                alt="La Violecion of My PapiYon poster"
                loading="lazy"
              />
            </div>
            <div class="pname">La Violecion of My PapiYon</div>
            <div class="pmeta">
              <span class="prole">Set Designer</span>SHADES, Wesleyan · '18
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/theater/life-is-a-dream.jpg"
                alt="Life is a Dream, Wesleyan CFA production photo"
                loading="lazy"
              />
            </div>
            <div class="pname">Life is a Dream</div>
            <div class="pmeta">
              <span class="prole">Actor · Clotaldo</span>Wesleyan CFA
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/theater/islands-poster.jpg"
                alt="Islands, Wesleyan CFA poster"
                loading="lazy"
              />
            </div>
            <div class="pname">Islands</div>
            <div class="pmeta">
              <span class="prole">Actor · Harjito / Sukarno</span>Wesleyan CFA ·
              '17
            </div>
          </div>

          <div class="poster">
            <div class="poster-frame poster-frame--img">
              <img
                src="/images/design/rhino.png"
                alt="Rhinoceros poster"
                loading="lazy"
              />
            </div>
            <div class="pname">Rhinoceros</div>
            <div class="pmeta">
              <span class="prole">Social Media</span>Second Stage, Wesleyan ·
              '18
            </div>
          </div>
        </div>
      </section>

      <!-- Credits -->
      <section class="t-section">
        <div class="t-sec-head">
          <div class="t-sec-num">b.</div>
          <div>
            <h2 class="t-h2">Credits.</h2>
            <div class="t-sec-sub">Synopsis · role</div>
          </div>
        </div>

        <div class="credits-list">
          <article class="credit">
            <div class="credit-idx">01</div>
            <div class="credit-body">
              <span class="credit-role">Director</span>
              <h3 class="credit-title">Disgraced</h3>
              <p class="credit-by">
                by Ayad Akhtar. Wesleyan Second Stage. December 6–8, 2018.
              </p>
              <dl class="credit-meta">
                <div>
                  <dt>Venue</dt><dd>
                    Malcolm X House · 345 High St, Lower Level
                  </dd>
                </div>
                <div><dt>Run</dt><dd>Dec 6 · 7 · 8, 2018</dd></div>
                <div>
                  <dt>Cast</dt><dd>
                    Arnaav Bhavanani · Ava Biery · Abhishek Fakiraswaminath ·
                    Dache Rogers · Skye Hawthorne
                  </dd>
                </div>
                <div><dt>Source</dt><dd>Pulitzer 2013</dd></div>
              </dl>
              <p class="credit-note">
                Ayad Akhtar's Pulitzer-winning one-act. A Pakistani-American
                corporate lawyer's hidden Muslim identity surfaces over a dinner
                party and blows everything apart. Two years earlier I'd acted in
                a Readers Theater reading of the same play as Hussein Malik/Abe
                Jensen, so I came to the script knowing it from the inside out.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> directed, and designed the
                poster. We set up in the basement of Malcolm X House, an improvised
                black box with borrowed furniture and Ikea dimmers where a lighting
                rig should have been. Stage manager: Thanmye Lagudu. Set designer:
                Angelica. <a href="/blog/sacred-geometry" class="content-link"
                  >I wrote about it.</a
                >
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">02</div>
            <div class="credit-body">
              <span class="credit-role">Stage Manager</span>
              <h3 class="credit-title">Really Really Gorgeous</h3>
              <p class="credit-by">
                by Nick Mecikalski. Directed by Miranda Haymon. The Tank, NYC.
              </p>
              <dl class="credit-meta">
                <div><dt>Venue</dt><dd>The Tank · 312 W 36th St</dd></div>
                <div><dt>Run</dt><dd>Jan 23 – Feb 9, 2020</dd></div>
                <div><dt>Premiere</dt><dd>World premiere</dd></div>
                <div><dt>Note</dt><dd>O'Neill 2017 finalist</dd></div>
              </dl>
              <p class="credit-note">
                Nick Mecikalski's world premiere, directed by Miranda Haymon.
                Two women in a moldy shack at the end of a flooded America; the
                play is a two-hander and it's relentless. Produced by The Tank
                with Lucy Powis and The Hodgepodge Group. Got a <a
                  href="https://www.nytimes.com/2020/02/03/theater/really-really-gorgeous-review.html"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="content-link">New York Times review</a
                >.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> stage managed. Kept the prompt
                book, ran rehearsals, called the show in performance, held the production
                schedule together through a packed run.
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">03</div>
            <div class="credit-body">
              <span class="credit-role">Stage Manager</span>
              <h3 class="credit-title">Action</h3>
              <p class="credit-by">
                by Sam Shepard. Directed by Ray Achan. Wesleyan senior thesis.
              </p>
              <dl class="credit-meta">
                <div><dt>Venue</dt><dd>Wesleyan University</dd></div>
                <div><dt>Year</dt><dd>2019</dd></div>
                <div><dt>Form</dt><dd>One act</dd></div>
                <div><dt>Source</dt><dd>Shepard, 1974</dd></div>
              </dl>
              <p class="credit-note">
                Sam Shepard's 1974 one-act. Four characters in an isolated cabin
                on Christmas, after some unspecified collapse outside; the play
                is very still and very tense. Ray Achan's directing thesis.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> stage managed. Kept the prompt
                book, ran rehearsals, called the show. Held the line between director
                and production so Ray could focus on the work.
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">04</div>
            <div class="credit-body">
              <span class="credit-role">Sound Designer</span>
              <h3 class="credit-title">Edith Can Shoot Things and Hit Them</h3>
              <p class="credit-by">
                by A. Rey Pamatmat. Wesleyan Second Stage.
              </p>
              <dl class="credit-meta">
                <div><dt>Venue</dt><dd>Second Stage, Wesleyan</dd></div>
                <div><dt>Year</dt><dd>2018</dd></div>
                <div><dt>Source</dt><dd>2011 Humana Festival</dd></div>
              </dl>
              <p class="credit-note">
                A. Rey Pamatmat's play about two Filipino American siblings
                living alone on a farm in Middle America; their parents left and
                didn't come back. A third character shows up and upsets the
                fragile equilibrium they've built. Originally produced at the
                2011 Humana Festival of New American Plays.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> designed sound. Built day-scene
                ambience and night-scene cue stacks, sourced and cut every cue, specced
                and patched the rig, ran sound through tech and performance.
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">05</div>
            <div class="credit-body">
              <span class="credit-role">Set Designer</span>
              <h3 class="credit-title">La Violecion of My PapiYon</h3>
              <p class="credit-by">
                by Arline Pierre-Louis. Directed by Ray Achan &amp; Ruby
                Fludzinski. SHADES, Wesleyan. April 19–21, 2018.
              </p>
              <dl class="credit-meta">
                <div>
                  <dt>Venue</dt><dd>Patricelli '92 Theater, Wesleyan</dd>
                </div>
                <div><dt>Run</dt><dd>Apr 19 · 20 · 21, 2018</dd></div>
                <div><dt>Producer</dt><dd>SHADES collective</dd></div>
                <div><dt>Form</dt><dd>New work, student-produced</dd></div>
              </dl>
              <p class="credit-note">
                New work by Arline Pierre-Louis, produced by SHADES, Wesleyan's
                student collective for theater by and about people of color.
                Directed by Ray Achan and Ruby Fludzinski. Ray also directed <em
                  >Action</em
                >, which I stage managed the following year.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> designed the set. Ground
                plan and elevations, build costing, supervised the build with the
                tech crew, paint and dressing.
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">06</div>
            <div class="credit-body">
              <span class="credit-role">Actor</span>
              <h3 class="credit-title">Life is a Dream</h3>
              <p class="credit-by">
                by Pedro Calderón de la Barca. Directed by Shira Milikowsky.
                Wesleyan Center for the Arts.
              </p>
              <dl class="credit-meta">
                <div><dt>Venue</dt><dd>Wesleyan CFA</dd></div>
                <div><dt>Year</dt><dd>2017</dd></div>
                <div><dt>Role</dt><dd>Clotaldo</dd></div>
                <div><dt>Source</dt><dd>Spanish Golden Age · 1635</dd></div>
              </dl>
              <p class="credit-note">
                Calderón de la Barca's verse drama, one of the great works of
                the Spanish Golden Age. Prince Segismundo has been imprisoned
                since birth by a prophecy; the play turns on whether fate can be
                escaped. CFA main-stage production, one of my first at Wesleyan.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> played Clotaldo, Segismundo's
                tutor and the keeper of the secret.
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">07</div>
            <div class="credit-body">
              <span class="credit-role">Actor</span>
              <h3 class="credit-title">Islands</h3>
              <p class="credit-by">
                Directed by Ronald Jenkins. Wesleyan Center for the Arts.
              </p>
              <dl class="credit-meta">
                <div><dt>Venue</dt><dd>Wesleyan CFA</dd></div>
                <div><dt>Year</dt><dd>2017</dd></div>
                <div><dt>Roles</dt><dd>Harjito / Sukarno</dd></div>
              </dl>
              <p class="credit-note">
                Ensemble-devised production on the CFA main stage, directed by
                Professor Ronald Jenkins. The work drew on island histories and
                collective memory; the form matched the content, built in the
                room by the room.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> played Harjito and Sukarno.
              </p>
            </div>
          </article>

          <article class="credit">
            <div class="credit-idx">08</div>
            <div class="credit-body">
              <span class="credit-role">Social Media Manager</span>
              <h3 class="credit-title">Rhinoceros</h3>
              <p class="credit-by">
                by Eugene Ionesco, translated by Derek Prouse. Directed by
                Jordan Tragash. Wesleyan Second Stage. May 3–5, 2018.
              </p>
              <dl class="credit-meta">
                <div>
                  <dt>Venue</dt><dd>Patricelli '92 Theater, Wesleyan</dd>
                </div>
                <div><dt>Run</dt><dd>May 3 · 4 · 5, 2018</dd></div>
                <div><dt>Assist. Dir.</dt><dd>Ray Achan</dd></div>
                <div><dt>Source</dt><dd>Ionesco, 1959</dd></div>
              </dl>
              <p class="credit-note">
                Ionesco's 1959 absurdist classic, in Derek Prouse's translation.
                A small French town's inhabitants begin turning into
                rhinoceroses one by one; the holdouts dwindle, resistance
                becomes its own kind of loneliness. One of the great plays about
                conformity and what it costs to refuse it.
              </p>
              <p class="credit-note">
                <span class="didwhat">What I did:</span> ran social media for the
                production. Wrote and scheduled posts, coordinated promotional assets
                with Jordan, pushed ticket sales through the three-night run.
              </p>
            </div>
          </article>
        </div>
      </section>

      <!-- Production photos -->
      <section class="t-section">
        <div class="t-sec-head">
          <div class="t-sec-num">c.</div>
          <div>
            <h2 class="t-h2">Photos.</h2>
            <div class="t-sec-sub">
              Disgraced · Dec 2018 · Photos by Elijah Comas
            </div>
          </div>
        </div>

        <div class="photos-grid">
          <figure class="photo-item photo-item--wide">
            <img
              src="/images/sacred-geometry/haha_isaac.jpg"
              alt="The dinner party scene: Arnaav Bhavanani, Abhishek Fakiraswaminath, Dache Rogers, Ava Biery"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/d5.JPG"
              alt="Arnaav Bhavanani as Amir"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/d1.JPG"
              alt="Dache Rogers, Arnaav Bhavanani, Abhishek Fakiraswaminath"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/d4.JPG"
              alt="Abhishek Fakiraswaminath and Ava Biery"
              loading="lazy"
            />
          </figure>
          <figure class="photo-item">
            <img
              src="/images/sacred-geometry/directing.png"
              alt="Rehearsal, Adam directing the cast"
              loading="lazy"
            />
          </figure>
        </div>
        <p class="photo-credit">
          Photography by Elijah Comas '22. Rehearsal photo by Thanmye Lagudu
          '20.
        </p>
      </section>

      <!-- Company -->
      <section class="t-section">
        <div class="t-sec-head">
          <div class="t-sec-num">d.</div>
          <div>
            <h2 class="t-h2">Company.</h2>
            <div class="t-sec-sub">Wesleyan Second Stage</div>
          </div>
        </div>

        <div class="company-block">
          <h3 class="company-name">Second Stage</h3>
          <div class="company-where">
            Student-run theater company · Wesleyan University
          </div>
          <div class="company-rows">
            <div class="company-row">
              <div class="company-role">
                Staff
                <em
                  >Two academic years on the company. Helped support productions
                  across the season: everything from load-ins to strike.</em
                >
              </div>
              <div class="company-year">2017 – 2019</div>
            </div>
            <div class="company-row">
              <div class="company-role">
                Lights &amp; Rigging Liaison
                <em
                  >Point person for the lighting rig and rigging hardware.
                  Coordinated with CFA technical staff on hangs and refocuses.</em
                >
              </div>
              <div class="company-year">2017 – 2018</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </Container>
</Layout>

<style>
  .theater-doc {
    padding: 3rem 0 5rem;
  }

  /* Title block */
  .theater-title {
    margin-bottom: 4rem;
  }

  .t-kicker {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.611rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .t-h1 {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
    color: var(--text);
  }

  .t-lede {
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--text-2);
    max-width: 620px;
    margin: 0 0 2.5rem;
  }

  /* Roles strip */
  .roles-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .role-cell {
    padding: 1rem 0.85rem;
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .role-cell:last-child {
    border-right: none;
  }

  .role-count {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.667rem;
    color: var(--accent-1);
    letter-spacing: 0.04em;
  }

  .role-name {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.556rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    margin-top: 0.2rem;
  }

  .role-note {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.5rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }

  /* Section structure */
  .t-section {
    margin-bottom: 4.5rem;
    scroll-margin-top: 2.5rem;
  }

  .t-sec-head {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--rule);
  }

  .t-sec-num {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.667rem;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    padding-top: 0.45rem;
  }

  .t-h2 {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 600;
    font-size: 1.55rem;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text);
  }

  .t-sec-sub {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.556rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }

  /* Posters grid */
  .posters-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .poster .poster-frame {
    aspect-ratio: 3/4;
    border: 1px solid var(--rule);
    position: relative;
    margin-bottom: 0.75rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 1rem;
    isolation: isolate;
  }

  .poster .poster-frame .pt {
    font-family: "Source Serif 4", Georgia, serif;
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.02;
    letter-spacing: -0.005em;
    text-align: center;
    z-index: 2;
    text-wrap: balance;
  }

  .poster .poster-frame .ptag {
    position: absolute;
    top: 0.65rem;
    left: 0.75rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.5rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    z-index: 2;
    opacity: 0.7;
  }

  .poster .poster-frame .pyr {
    position: absolute;
    bottom: 0.65rem;
    right: 0.75rem;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    z-index: 2;
    opacity: 0.7;
  }

  .poster .pname {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 0.85rem;
    font-weight: 600;
    font-style: italic;
    margin-bottom: 0.1rem;
    color: var(--text);
  }

  .poster .pmeta {

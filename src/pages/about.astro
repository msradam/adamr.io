---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { ABOUT } from "@consts";
---

<Layout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <div class="space-y-6">
      <div
        class="flex flex-col gap-5 sm:flex-row sm:items-start"
        style="padding-bottom: 1.5rem; border-bottom: 1px solid var(--rule);"
      >
        <img
          src="/images/headshot.png"
          alt="Adam M. Rahman"
          class="size-24 shrink-0 object-cover"
          style="border: 1px solid var(--border-strong);"
        />
        <div>
          <h1 class="page-heading-sm">Adam Rahman</h1>
          <p class="body-text-sm" style="margin-top: 0.25rem;">
            Software engineer at IBM &middot; M.S. Computer Engineering, NYU
            Tandon &middot; B.A. Theater & Computer Science, Wesleyan
          </p>
          <p class="body-text-xs" style="margin-top: 0.35rem;">
            Engineer, poet, and theatermaker. My work keeps returning to the
            same questions: who gets seen, who gets counted, and the dignity of
            people who cannot opt out.
          </p>
        </div>
      </div>

      <div class="about-layout">
        <article class="prose about-prose">
          <p>
            I'm a software engineer at <Link
              href="https://www.ibm.com/z"
              external>IBM</Link
            > in New York, on enterprise resiliency testing and automation for the
            IBM Z mainframe. I replace legacy testing tools with modern open-source
            frameworks: porting <Link
              href="https://grafana.com/oss/k6/"
              external>Grafana k6</Link
            > natively to z/OS, load-testing 3270 terminals, and building CI/CD for
            mainframe infrastructure. Several are open source, including <Link
              href="/dev/xk6-tn3270">xk6-tn3270</Link
            >, <Link href="/dev/xk6-llm">xk6-llm</Link>, and <Link
              href="/dev/fromjcl">fromjcl</Link
            >.
          </p>
          <p>
            Outside that, I build at the intersection of geospatial AI and
            humanitarian use. <Link href="/dev/dream-meridian"
              >DreamMeridian</Link
            >
            runs AI geospatial queries entirely offline on a Raspberry Pi, for places
            with no reliable network; it placed 2nd in the ARM AI Developer Challenge
            and was <Link
              href="https://engineering.nyu.edu/news/meet-adam-munawar-rahman-leveraging-ai-humanitarian-use"
              external>profiled by NYU Tandon</Link
            >. <Link href="/dev/amanat">amanat</Link> scans an NGO's cloud accounts
            for exposed beneficiary data and remediates it on-device. The thread runs
            back to UNICEF, where I built routing for school-site planning. It's the
            subject I've worked on since I was an undergraduate: who gets seen, who
            gets counted, and what systems do to people who can't opt out.
          </p>
          <p>
            I hold a B.A. in Theater and Computer Science from <Link
              href="https://www.wesleyan.edu/"
              external>Wesleyan</Link
            >, and I'm finishing an M.S. in Computer Engineering at <Link
              href="https://engineering.nyu.edu/"
              external>NYU Tandon</Link
            >. I'm also a poet and theatermaker: my work has appeared in <Link
              href="https://www.barzakhmag.net/spring-2026-poetry-blog/2026/3/19/adam-munawar-rahman"
              external>Barzakh Magazine</Link
            >, <Link href="https://heartonoursleeves.press" external
              ><em>Collide-oscope</em></Link
            >, and <Link
              href="https://www.fourtulips.com/archives/padma"
              external>Four Tulips</Link
            >, and I've directed, stage-managed, and <Link href="/design"
              >designed</Link
            > for the stage. Writing, theater, and software have always been one kind
            of work for me: making something in response to what I notice.
          </p>
        </article>

        <aside class="about-rail">
          <div class="rail-stack">
            <span class="rail-stack-label">At a glance</span>
            <ul class="rail-chips">
              <li class="rail-chip">Go</li>
              <li class="rail-chip">Python</li>
              <li class="rail-chip">Rust/WASM</li>
              <li class="rail-chip">TypeScript</li>
              <li class="rail-chip">z/OS</li>
              <li class="rail-chip">Grafana k6</li>
              <li class="rail-chip">MCP</li>
              <li class="rail-chip">Ansible</li>
              <li class="rail-chip">Jenkins</li>
              <li class="rail-chip">load testing</li>
              <li class="rail-chip">observability</li>
              <li class="rail-chip">agentic AI</li>
              <li class="rail-chip">geospatial</li>
            </ul>
          </div>
          <dl class="about-facts">
            <div class="fact-row">
              <dt>Based</dt>
              <dd>NYC &middot; Eastern Time</dd>
            </div>
            <div class="fact-row">
              <dt>Now</dt>
              <dd>
                Resiliency testing &amp; automation, IBM Z &middot; NYU Tandon
              </dd>
            </div>
            <div class="fact-row">
              <dt>Education</dt>
              <dd>Wesleyan &middot; Theater & CS &middot; 2020</dd>
            </div>
            <div class="fact-row">
              <dt>GitHub</dt>
              <dd>
                <Link href="https://github.com/msradam" external>msradam</Link>
              </dd>
            </div>
            <div class="fact-row">
              <dt>LinkedIn</dt>
              <dd>
                <Link href="https://linkedin.com/in/adamsrahman" external
                  >adamsrahman</Link
                >
              </dd>
            </div>
            <div class="fact-row">
              <dt>Medium</dt>
              <dd>
                <Link href="https://medium.com/@msradam" external>@msradam</Link
                >
              </dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </Container>
</Layout>

<style>
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 160px;
    gap: 3rem;
    align-items: start;
  }

  .about-rail {
    padding-top: 0.25rem;
  }

  .rail-stack {
    margin-bottom: 1.25rem;
  }

  .rail-stack-label {
    display: block;
    font-family: var(--mono);
    font-size: var(--label); /* VT323 optical bump from 0.611 */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-2);
    margin-bottom: 0.5rem;
  }

  .rail-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .rail-chip {
    font-family: var(--mono);
    font-size: 0.667rem; /* VT323 optical bump from 0.583 */
    letter-spacing: 0.04em;
    color: var(--text-2);
    border: 1px solid var(--rule);
    padding: 0.08rem 0.4rem;
    background: var(--bg-alt);
  }

  .about-facts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .fact-row {
    display: flex;
    flex-direction: column;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .fact-row:first-child {
    border-top: 1px solid var(--rule);
  }

  .fact-row dt {
    font-family: var(--mono);
    font-size: 0.667rem; /* VT323 optical bump from 0.611 */
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-2);
    margin: 0;
  }

  .fact-row dd {
    font-family: var(--sans);
    font-size: 0.833rem;
    color: var(--text-2);
    margin: 0.15rem 0 0;
  }

  @media (max-width: 640px) {
    .about-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-rail {
      order: -1;
    }
  }
</style>

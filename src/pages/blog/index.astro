---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { BLOG } from "@consts";

const all = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const TOPICS: {
  key: "ai-infra" | "observability" | "essays";
  label: string;
}[] = [
  { key: "ai-infra", label: "AI infrastructure & agents" },
  { key: "observability", label: "Observability & tooling" },
  { key: "essays", label: "Essays & reflections" },
];

const byTopic = TOPICS.map(({ key, label }) => ({
  label,
  posts: all.filter((p) => p.data.topic === key),
})).filter((g) => g.posts.length > 0);
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <div>
          <span class="section-label">Writings</span>
          <h1
            class="page-heading"
            style="margin-top: 0.5rem; margin-bottom: 0;"
          >
            Selected writings, by topic.
          </h1>
          <p class="writings-lede">
            Essays on AI infrastructure, observability, and occasional other
            subjects.
          </p>
        </div>

        {
          byTopic.map(({ label, posts }) => (
            <section class="space-y-2">
              <div class="section-header">
                <span class="section-label">{label}</span>
                <span class="row-meta">
                  {posts.length} {posts.length === 1 ? "post" : "posts"}
                </span>
              </div>
              <ul class="ruled-list">
                {posts.map((post) => (
                  <li>
                    <ArrowCard entry={post} />
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </aside>
  </Container>
</Layout>

<style>
  .writings-lede {
    font-family: var(--sans);
    font-size: 1rem;
    color: var(--text-2);
    line-height: 1.55;
    max-width: 52ch;
    margin-top: 0.5rem;
  }
</style>

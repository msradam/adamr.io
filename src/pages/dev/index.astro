---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { PROJECTS } from "@consts";

const all = (await getCollection("dev"))
  .filter((p) => !p.data.draft && !p.data.hidden)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rank = (p: (typeof all)[number]) =>
  p.data.featuredRank ?? Number.MAX_SAFE_INTEGER;
const featured = all
  .filter((p) => p.data.featured)
  .sort((a, b) => rank(a) - rank(b));
const recent = all.filter((p) => !p.data.featured);

const thumbPath: Record<string, string> = {
  "dream-meridian": "/images/dreammeridian.png",
  amanat: "/images/amanat.png",
  "xk6-tn3270": "/images/locust-zos.gif",
  "xk6-llm": "/images/xk6-llm-dash.png",
  "riprap-nyc": "/images/riprap-nyc.png",
  kassandra: "/images/kassandra.jpg",
  theodosia: "/images/theodosia.gif",
  leavitt: "/images/leavitt.png",
  fromjcl: "/images/fromjcl.gif",
};
function thumbSrc(id: string) {
  return thumbPath[id];
}

const OSS_IDS = new Set(["xk6-llm", "xk6-tn3270"]);

function statusLabel(p: (typeof all)[number]) {
  const role = p.data.role ?? "";
  if (OSS_IDS.has(p.id) || /OSS|Open source/i.test(role)) return "Open source";
  if (/Hackathon/.test(role) || p.data.venue?.includes("Hackathon"))
    return "Hackathon";
  if (/IBM/.test(role)) return "Work @ IBM";
  if (/Research/.test(role)) return "Research";
  if (/UNICEF/.test(role)) return "UNICEF";
  return null;
}
---

<Layout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div>
        <span class="section-label">Projects</span>
        <h1 class="page-heading" style="margin-top: 0.5rem; margin-bottom: 0;">
          A working list of things I've built.
        </h1>
        <p
          class="body-text-sm"
          style="margin-top: 0.5rem; color: var(--text-muted);"
        >
          Hackathon-winning civic-AI, open-source tooling, and geospatial
          systems. Most have public repos.
        </p>
      </div>

      {
        featured.length > 0 && (
          <section class="space-y-3">
            <div class="section-header">
              <span class="section-label">Featured</span>
              <span class="row-meta">
                {String(featured.length).padStart(2, "0")}
              </span>
            </div>
            <div class="feat-grid">
              {featured.map((p) => (
                <a href={`/dev/${p.id}`} class="feat-card">
                  {thumbSrc(p.id) && (
                    <div class="feat-thumb">
                      <img
                        src={thumbSrc(p.id)}
                        alt={p.data.title}
                        loading="lazy"
                      />
                    </div>
                  )}
                  <div class="feat-body">
                    <div class="feat-title">
                      <span>{p.data.title}</span>
                      {statusLabel(p) && (
                        <span class="status-tag">{statusLabel(p)}</span>
                      )}
                    </div>
                    <div class="feat-desc">{p.data.description}</div>
                    <div class="feat-meta">
                      <span>
                        {p.data.stack
                          ? p.data.stack.slice(0, 3).join(" · ")
                          : (p.data.role ?? "")}
                      </span>
                      <span class="row-meta">{p.data.date.getFullYear()}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        recent.length > 0 && (
          <section class="space-y-2">
            <div class="section-header">
              <span class="section-label">Recent</span>
              <span class="row-meta">
                {recent.length} {recent.length === 1 ? "project" : "projects"}
              </span>
            </div>
            <ul class="ruled-list">
              {recent.map((p) => (
                <li>
                  <a
                    href={`/dev/${p.id}`}
                    class="ruled-row no-number recent-row"
                  >
                    <span class="recent-main">
                      <span class="recent-head">
                        <span class="row-title">{p.data.title}</span>
                        {statusLabel(p) && (
                          <span class="status-tag">{statusLabel(p)}</span>
                        )}
                      </span>
                      <span class="recent-desc">{p.data.description}</span>
                    </span>
                    <span class="row-meta">{p.data.date.getFullYear()}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </div>
  </Container>
</Layout>

<style>
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .feat-card {
    background: var(--bg-alt);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .feat-card:hover {
    border-color: var(--rule-strong);
  }

  .feat-thumb {
    aspect-ratio: 4/3;
    border-bottom: 1px solid var(--rule);
    overflow: hidden;
    background: var(--bg-alt);
  }

  .feat-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feat-body {
    padding: 0.85rem 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.35rem;
  }

  .feat-title {
    font-family: var(--mono);
    font-size: 0.722rem;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .status-tag {
    font-family: var(--mono);
    font-size: var(--meta); /* VT323 optical bump from 0.5 */
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--rule);
    padding: 0.05rem 0.35rem;
    white-space: nowrap;
  }

  .recent-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .feat-desc {
    font-family: var(--sans);
    font-size: 0.778rem;
    line-height: 1.5;
    color: var(--text-2);
    flex: 1;
  }

  .feat-meta {
    font-family: var(--mono);
    font-size: var(--meta); /* VT323 optical bump from 0.556 */
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 0.25rem;
  }

  .recent-row {
    align-items: baseline;
  }

  .recent-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .recent-main :global(.row-title) {
    white-space: normal;
  }

  .recent-desc {
    font-family: var(--sans);
    font-size: 0.778rem;
    line-height: 1.45;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .feat-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  @media (min-width: 480px) and (max-width: 720px) {
    .feat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

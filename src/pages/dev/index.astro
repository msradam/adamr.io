---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { PROJECTS } from "@consts";

const all = (await getCollection("dev"))
  .filter((p) => !p.data.draft && !p.data.hidden)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = all.filter((p) => p.data.featured);

const ARCHIVE_CUTOFF = new Date("2023-01-01");
const rest = all.filter((p) => !p.data.featured);
const recent = rest.filter((p) => p.data.date >= ARCHIVE_CUTOFF);
const archive = rest.filter((p) => p.data.date < ARCHIVE_CUTOFF);

const archiveByYear = archive.reduce(
  (acc, p) => {
    const y = p.data.date.getFullYear().toString();
    if (!acc[y]) acc[y] = [];
    acc[y].push(p);
    return acc;
  },
  {} as Record<string, typeof archive>,
);
const archiveYears = Object.keys(archiveByYear).sort(
  (a, b) => parseInt(b) - parseInt(a),
);

const thumbPath: Record<string, string> = {
  "dream-meridian": "/images/dreammeridian.png",
  "xk6-llm": "/images/xk6-llm-dash.png",
  "locust-zos": "/images/locust-zos.gif",
  kassandra: "/images/kassandra.jpg",
  theodosia: "/images/theodosia.gif",
  fromjcl: "/images/fromjcl.gif",
};
function thumbSrc(id: string) {
  return thumbPath[id] ?? `/images/${id}.png`;
}

const containThumbs = new Set(["kassandra", "amanat"]);
---

<Layout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div>
        <span class="section-label">Projects</span>
        <h1 class="page-heading" style="margin-top: 0.5rem; margin-bottom: 0;">
          A working list of things I've built.
        </h1>
        <p
          class="body-text-sm"
          style="margin-top: 0.5rem; color: var(--text-muted);"
        >
          Civic-AI systems, observability extensions, and hackathon projects.
          Most have repos.
        </p>
      </div>

      {
        featured.length > 0 && (
          <section class="space-y-3">
            <div class="section-header">
              <span class="section-label">Featured</span>
              <span class="row-meta">
                {String(featured.length).padStart(2, "0")}
              </span>
            </div>
            <div class="feat-grid">
              {featured.map((p) => (
                <a href={`/dev/${p.id}`} class="feat-card">
                  <div
                    class={`feat-thumb${containThumbs.has(p.id) ? " feat-thumb--contain" : ""}`}
                  >
                    <img
                      src={thumbSrc(p.id)}
                      alt={p.data.title}
                      loading="lazy"
                    />
                  </div>
                  <div class="feat-body">
                    <div class="feat-title">{p.data.title}</div>
                    <div class="feat-desc">{p.data.description}</div>
                    <div class="feat-meta">
                      <span>
                        {p.data.stack
                          ? p.data.stack.slice(0, 3).join(" · ")
                          : (p.data.role ?? "")}
                      </span>
                      <span class="row-meta">{p.data.date.getFullYear()}</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }

      {
        recent.length > 0 && (
          <section class="space-y-2">
            <div class="section-header">
              <span class="section-label">Recent</span>
              <a href="#archive" class="meta-link">
                See archive
              </a>
            </div>
            <ul class="ruled-list">
              {recent.map((p, i) => (
                <li>
                  <a href={`/dev/${p.id}`} class="ruled-row">
                    <span class="row-num">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="row-title">{p.data.title}</span>
                    <span class="row-meta">
                      {p.data.role && (
                        <span style="margin-right: 0.6em;">
                          {p.data.role.split("·")[0].trim()}
                        </span>
                      )}
                      {p.data.date.getFullYear()}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {
        archive.length > 0 && (
          <section id="archive" class="space-y-4">
            <div class="section-header">
              <span class="section-label">Archive</span>
              <span class="row-meta">{archive.length} items</span>
            </div>
            {archiveYears.map((year) => (
              <div>
                <div class="archive-year">{year}</div>
                <ul class="ruled-list">
                  {archiveByYear[year].map((p) => (
                    <li>
                      <a href={`/dev/${p.id}`} class="ruled-row no-number">
                        <span class="row-title">{p.data.title}</span>
                        <span class="row-meta">
                          {p.data.date.getFullYear()}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        )
      }
    </div>
  </Container>
</Layout>

<style>
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .feat-card {
    background: var(--bg-alt);
    border: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .feat-card:hover {
    border-color: var(--rule-strong);
  }

  .feat-thumb {
    aspect-ratio: 4/3;
    border-bottom: 1px solid var(--rule);
    overflow: hidden;
    background: var(--bg-alt);
  }

  .feat-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .feat-thumb--contain {
    background: #0c0c0c;
  }

  .feat-thumb--contain img {
    object-fit: contain;
  }

  .feat-body {
    padding: 0.85rem 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.35rem;
  }

  .feat-title {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.722rem;
    font-weight: 600;
    color: var(--text);
  }

  .feat-desc {
    font-family: "Source Serif 4", Georgia, serif;
    font-size: 0.778rem;
    line-height: 1.5;
    color: var(--text-2);
    flex: 1;
  }

  .feat-meta {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.556rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 0.25rem;
  }

  .archive-year {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.611rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  @media (max-width: 720px) {
    .feat-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }

  @media (min-width: 480px) and (max-width: 720px) {
    .feat-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

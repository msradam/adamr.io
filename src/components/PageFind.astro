---
import Search from "astro-pagefind/components/Search";
---

<aside data-pagefind-ignore>
  <div
    transition:persist
    id="backdrop"
    class="invisible fixed top-0 left-0 z-50 flex h-screen w-full justify-center p-6"
    style="background: rgba(0,0,0,0.4); backdrop-filter: blur(2px);"
  >
    <div
      id="pagefind-container"
      class="m-0 flex h-fit max-h-[80%] w-full max-w-[680px] flex-col overflow-auto p-2 px-4 py-3 shadow-lg"
      style="background: var(--bg); border: 1px solid var(--rule); border-radius: 3px;"
    >
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{
          showImages: false,
          excerptLength: 15,
          resetStyles: false,
        }}
      />
      <div
        class="mr-2 pt-4 pb-1 text-right"
        style="font-size: 0.6rem; color: var(--text-muted);"
      >
        Press <kbd
          style="font-family: var(--mono); font-size: 0.6rem; background: var(--bg-alt); border: 1px solid var(--rule); border-radius: 2px; padding: 0.1em 0.3em;"
          >Esc</kbd
        > or click anywhere to close
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  const magnifyingGlass = document.getElementById("magnifying-glass");
  const backdrop = document.getElementById("backdrop");

  function openPagefind() {
    const searchDiv = document.getElementById("search");
    const search = searchDiv.querySelector("input");
    setTimeout(() => {
      search.focus();
    }, 0);
    backdrop?.classList.remove("invisible");
    backdrop?.classList.add("visible");
  }

  function closePagefind() {
    const search = document.getElementById("search");
    search.value = "";
    backdrop?.classList.remove("visible");
    backdrop?.classList.add("invisible");
  }

  magnifyingGlass?.addEventListener("click", () => {
    openPagefind();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "/") {
      e.preventDefault();
      openPagefind();
    } else if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      openPagefind();
    }
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closePagefind();
    }
  });

  document.addEventListener("click", (event) => {
    if (event.target.classList.contains("pagefind-ui__result-link")) {
      closePagefind();
    }
  });

  backdrop?.addEventListener("click", (event) => {
    if (!event.target.closest("#pagefind-container")) {
      closePagefind();
    }
  });

  const form = document.getElementById("form");
  form?.addEventListener("submit", (event) => {
    event.preventDefault();
  });
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.75;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 3px;
    --pagefind-ui-font: var(--mono);
    --pagefind-ui-primary: var(--text-2);
    --pagefind-ui-text: var(--text-2);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--rule-strong);
    --pagefind-ui-tag: var(--tag-bg);
  }

  #search input {
    font-weight: normal;
  }

  /* search input border must clear 3:1 as a UI component boundary (1.4.11) */
  #search .pagefind-ui__search-input {
    border-color: var(--text-muted);
  }

  #search p {
    font-weight: normal;
  }

  #search .pagefind-ui__result-title {
    font-weight: 600;
  }

  #search .pagefind-ui__message {
    padding: 0;
    padding-bottom: 0.75rem;
  }
</style>

---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content="Adam M. Rahman" />

<!-- Fonts are self-hosted (Lokta / SIL OFL) and bundled through global.css. -->

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="adamr.io" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={new URL(image, Astro.url)} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{image && <meta property="twitter:image" content={new URL(image, Astro.url)} />}

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title="Adam M. Rahman"
  href="/rss.xml"
/>

<!-- Iconify -->
<script
  is:inline
  src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"
></script>

<!-- PageFind -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>

<!-- Structured data -->
<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Adam M. Rahman",
    "url": "https://adamr.io",
    "jobTitle": "Software Engineer",
    "worksFor": { "@type": "Organization", "name": "IBM" },
    "alumniOf": [
      {
        "@type": "EducationalOrganization",
        "name": "NYU Tandon School of Engineering"
      },
      { "@type": "EducationalOrganization", "name": "Wesleyan University" }
    ],
    "knowsAbout": [
      "enterprise resiliency",
      "resiliency testing",
      "performance and load testing",
      "chaos and resilience engineering",
      "observability",
      "mainframe engineering",
      "z/OS",
      "geospatial AI",
      "civic AI",
      "poetry",
      "theater",
      "graphic design"
    ],
    "sameAs": [
      "https://github.com/msradam",
      "https://linkedin.com/in/adamsrahman",
      "https://medium.com/@msradam",
      "https://engineering.nyu.edu/news/meet-adam-munawar-rahman-leveraging-ai-humanitarian-use"
    ]
  }
</script>

<ClientRouter />

<script is:inline>
  /* Synchronous theme apply: runs before paint to prevent FOUC */
  (function () {
    var stored;
    try {
      stored = localStorage.getItem("adamr-theme");
    } catch (e) {}
    var valid = ["paper", "ink", "bone", "indigo"];
    var theme = stored && valid.indexOf(stored) !== -1 ? stored : "indigo";
    document.documentElement.setAttribute("data-theme", theme);
  })();

  var THEME_CYCLE = ["paper", "ink", "bone", "indigo"];
  var THEME_LABELS = {
    paper: "Paper",
    ink: "Ink",
    bone: "Bone",
    indigo: "Indigo",
  };

  function syncToggleLabel() {
    var toggle = document.getElementById("theme-toggle");
    if (!toggle) return;
    var current =
      document.documentElement.getAttribute("data-theme") || "indigo";
    var idx = THEME_CYCLE.indexOf(current);
    var next = THEME_CYCLE[(idx + 1) % THEME_CYCLE.length];
    toggle.textContent = THEME_LABELS[current] || "Paper";
    toggle.setAttribute(
      "aria-label",
      "Display stock: " +
        (THEME_LABELS[current] || "Paper") +
        ". Activate to switch to " +
        (THEME_LABELS[next] || "Ink") +
        ".",
    );
  }

  function toggleTheme() {
    var current =
      document.documentElement.getAttribute("data-theme") || "indigo";
    var idx = THEME_CYCLE.indexOf(current);
    var next = THEME_CYCLE[(idx + 1) % THEME_CYCLE.length];
    document.documentElement.setAttribute("data-theme", next);
    try {
      localStorage.setItem("adamr-theme", next);
    } catch (e) {}
    syncToggleLabel();
  }

  function initWaveReplay() {
    var wave = document.querySelector(".wave-icon");
    if (!wave || !wave.parentElement) return;
    var greeting = wave.parentElement;
    greeting.addEventListener("mouseenter", function () {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      wave.style.animation = "none";
      void wave.offsetWidth;
      wave.style.animation = "";
    });
  }

  function setHeaderHeight() {
    var h = document.querySelector("header");
    if (h)
      document.documentElement.style.setProperty(
        "--header-h",
        h.offsetHeight + "px",
      );
  }

  function onScroll() {
    if (window.scrollY > 0) {
      document.documentElement.classList.add("scrolled");
    } else {
      document.documentElement.classList.remove("scrolled");
    }
    var bar = document.getElementById("read-progress-bar");
    if (bar) {
      var isArticle = document.querySelector(".post-prose, .project-content");
      if (isArticle) {
        var el = document.documentElement;
        var max = el.scrollHeight - el.clientHeight;
        bar.style.width = (max > 0 ? (el.scrollTop / max) * 100 : 0) + "%";
      } else {
        bar.style.width = "0%";
      }
    }
  }

  function scrollToTop(event) {
    event.preventDefault();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function addCopyCodeButtons() {
    var copyButtonLabel = "Copy";
    var codeBlocks = Array.from(document.querySelectorAll("pre"));

    async function copyCode(codeBlock, copyButton) {
      var codeText = codeBlock.innerText;
      var buttonText = copyButton.innerText;
      var textToCopy = codeText.replace(buttonText, "");
      await navigator.clipboard.writeText(textToCopy);
      copyButton.innerText = "Copied!";
      setTimeout(function () {
        copyButton.innerText = copyButtonLabel;
      }, 2000);
    }

    for (var codeBlock of codeBlocks) {
      var wrapper = document.createElement("div");
      wrapper.style.position = "relative";
      var copyButton = document.createElement("button");
      copyButton.innerText = copyButtonLabel;
      copyButton.classList = "copy-code";
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);
      codeBlock.parentNode.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);
      copyButton.addEventListener(
        "click",
        (function (cb, btn) {
          return async function () {
            await copyCode(cb, btn);
          };
        })(codeBlock, copyButton),
      );
    }
  }

  function init() {
    syncToggleLabel();
    setHeaderHeight();
    onScroll();
    addCopyCodeButtons();
    initWaveReplay();

    var backToTop = document.getElementById("back-to-top");
    if (backToTop) backToTop.addEventListener("click", scrollToTop);

    var backToPrev = document.getElementById("back-to-prev");
    if (backToPrev)
      backToPrev.addEventListener("click", function () {
        window.history.back();
      });

    // Toggle lives in the persisted header, so dedupe across view transitions.
    var themeToggle = document.getElementById("theme-toggle");
    if (themeToggle) {
      themeToggle.removeEventListener("click", toggleTheme);
      themeToggle.addEventListener("click", toggleTheme);
    }
  }

  if (!window.__initReady) {
    window.__initReady = true;
    document.addEventListener("DOMContentLoaded", init);
    document.addEventListener("astro:before-swap", function (e) {
      var current = document.documentElement.getAttribute("data-theme");
      if (current)
        e.newDocument.documentElement.setAttribute("data-theme", current);
    });
    document.addEventListener("astro:after-swap", init);
    document.addEventListener("scroll", onScroll);
    window.addEventListener("resize", setHeaderHeight);
  }

  init();
</script>

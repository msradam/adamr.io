---

---

<header transition:persist>
  <div class="header-inner">
    <a href="/" class="site-name">
      <span class="site-name__accent">a</span>damr.io<span class="cursor"
        >_</span
      >
    </a>
    <nav class="topbar-nav" aria-label="Primary">
      <a href="/blog" class="nav-link">blog</a>
      <a href="/dev" class="nav-link">dev</a>
      <a href="/poetry" class="nav-link">poetry</a>
      <a href="/design" class="nav-link">design</a>
      <a href="/theater" class="nav-link">theater</a>
      <a href="/about" class="nav-link">about</a>
      <button
        id="magnifying-glass"
        aria-label="Search"
        class="nav-link search-btn"
      >
        <svg
          height="12"
          width="12"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M3.5 7C3.5 5.067 5.067 3.5 7 3.5C8.933 3.5 10.5 5.067 10.5 7C10.5 7.88461 10.1718 8.69256 9.63058 9.30876L9.30876 9.63058C8.69256 10.1718 7.88461 10.5 7 10.5C5.067 10.5 3.5 8.933 3.5 7ZM9.96544 11.0261C9.13578 11.6382 8.11014 12 7 12C4.23858 12 2 9.76142 2 7C2 4.23858 4.23858 2 7 2C9.76142 2 12 4.23858 12 7C12 8.11014 11.6382 9.13578 11.0261 9.96544L14.0303 12.9697L14.5607 13.5L13.5 14.5607L12.9697 14.0303L9.96544 11.0261Z"
          ></path>
        </svg>
      </button>
      <button
        id="theme-toggle"
        aria-label="Display stock: Indigo. Activate to switch to Paper."
        class="theme-toggle"
        type="button">Indigo</button
      >
    </nav>
  </div>
  <div class="read-progress" aria-hidden="true">
    <div class="read-progress-bar" id="read-progress-bar"></div>
  </div>
</header>

<style>
  .header-inner {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 22px 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  .topbar-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem;
  }

  .site-name__accent {
    color: var(--accent);
  }

  .search-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.3rem;
    margin-left: 0.2rem;
  }

  @media (max-width: 720px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.6rem;
    }
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 18px 1.25rem;
    }
  }
</style>

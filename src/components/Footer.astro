---
import Container from "@components/Container.astro";
---

<footer>
  <Container>
    <div class="relative">
      <div class="absolute -top-10 right-0">
        <button
          id="back-to-top"
          aria-label="Back to top"
          class="back-link cursor-pointer"
          style="font-size: 0.55rem;"
        >
          Top &uarr;
        </button>
      </div>
    </div>
    <div
      class="flex items-center justify-between"
      style="font-family: var(--font-mono);"
    >
      <span>adamr.io</span>
      <span>&copy; {new Date().getFullYear()}</span>
    </div>
    <div class="footer-a11y" style="font-family: var(--font-mono);">
      Built to WCAG 2.2 AA &middot; <a
        href="https://linkedin.com/in/adamsrahman"
        target="_blank"
        rel="noopener noreferrer">Report a barrier</a
      >
    </div>
  </Container>
</footer>

<style>
  .footer-a11y {
    margin-top: 0.4rem;
    color: var(--text-muted);
  }
  .footer-a11y a {
    color: var(--text-muted);
    border-bottom: 1px solid var(--rule);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .footer-a11y a:hover {
    color: var(--text);
    border-color: var(--rule-strong);
  }
</style>
